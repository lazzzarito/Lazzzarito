---
import { Icon } from 'astro-icon/components';
import localTechData from '../data/tech.json';

interface Skill {
  name: string;
  icon: string;
}

interface Category {
  title: string;
  skills: Skill[];
}

const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
let skills: Skill[];

try {
  if (BASE_URL) {
    const response = await fetch(`${BASE_URL}/tech`);
    const data = await response.json();
    // Support both flat skills list and legacy categories from API
    skills = data.skills ?? data.categories?.flatMap((c: Category) => c.skills) ?? [];
  } else {
    skills = localTechData.skills;
  }
} catch {
  skills = localTechData.skills;
}
---

<section id="tech" class="section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="tech-header mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Tech Stack
      </h2>
      <p class="text-subtext font-body text-sm max-w-md">
        Tools and technologies I work with day to day
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7 gap-5 sm:gap-8">
      {skills.map((skill) => (
        <div class="skill-card opacity-0 group flex items-stretch min-h-14 rounded-xl bg-accent/5 border border-accent/15 hover:border-accent/40 hover:bg-accent/10 transition-all duration-300">
          <div class="shrink-0 w-12 flex items-center justify-center rounded-l-xl bg-accent/15 transition-colors group-hover:bg-accent/20">
            <Icon name={skill.icon} class="w-7 h-7 group-hover:scale-110 transition-transform" />
          </div>
          
          <div class="flex items-center px-3 py-2 overflow-hidden w-full">
            <span class="font-body text-maintext/90 text-[13px] leading-tight font-medium tracking-tight line-clamp-2">
              {skill.name}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Header Initial State */
  .tech-header {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Initial state of the card */
  .skill-card {
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Shared Revealed state */
  .tech-header.reveal,
  .skill-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealSkills() {
    const header = document.querySelector('.tech-header');
    const cards = document.querySelectorAll('.skill-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target;
          
          // Check if the intersecting element is the header
          if (target.classList.contains('tech-header')) {
            target.classList.add('reveal');
            observer.unobserve(target);
          }
          // Check if the intersecting element is a skill card
          else if (target.classList.contains('skill-card')) {
            // Add a slight delay based on the card's position to create a wave effect
            const index = Array.from(cards).indexOf(target);
            setTimeout(() => {
              target.classList.add('reveal');
            }, (index % 6) * 50); // Delay resets every row for a clean staggered look
            
            observer.unobserve(target);
          }
        }
      });
    }, {
      threshold: 0.1, // Trigger when 10% of the card is visible
      rootMargin: '0px 0px -50px 0px' // Trigger slightly before it hits the viewport
    });

    // Observe the header
    if (header) observer.observe(header);

    // Observe all cards
    cards.forEach(card => observer.observe(card));
  }

  // Runs on initial load
  revealSkills();
  
  // Necessary for Astro View Transitions if you use them
  document.addEventListener('astro:after-swap', revealSkills);
</script>

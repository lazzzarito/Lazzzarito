---

const projects = [
  {
    url: "https://liztalfonso.com",
    img: "/images/lizt.webp",
    alt: "Lizt Alfonso Dance Cuba",
    i18nCat: "works.cat1", cat: "Company & school",
    i18nTitle: "works.title1", title: "Lizt Alfonso Dance Cuba",
    i18nDesc: "works.desc1", desc: "Dance-based site for classes, events, and booking info.",
    stack: [
      { i18n: "works.stack1.1", label: "WordPress" },
      { i18n: "works.stack1.2", label: "WooCommerce" },
      { i18n: "works.stack1.3", label: "PHP" },
    ],
  },
  {
    url: "https://bacuba.org/",
    img: "/images/bac.webp",
    alt: "Bienestar Animal Cuba",
    i18nCat: "works.cat2", cat: "Nonprofit",
    i18nTitle: "works.title2", title: "Bienestar Animal Cuba",
    i18nDesc: "works.desc2", desc: "Animal welfare site with donation, adoption, and volunteer info.",
    stack: [
      { i18n: "works.stack2.1", label: "WordPress" },
      { i18n: "works.stack2.2", label: "PHP" },
      { i18n: "works.stack2.3", label: "Donation Plugins" },
    ],
  },
  {
    url: "https://alexsgoldjoyeria.com/",
    img: "/images/alexs.webp",
    alt: "Alex's Gold Joyería",
    i18nCat: "works.cat3", cat: "Jewelry brand",
    i18nTitle: "works.title3", title: "Alex's Gold Joyería",
    i18nDesc: "works.desc3", desc: "Clean product gallery with a premium, polished feel.",
    stack: [
      { i18n: "works.stack3.1", label: "Shopify" },
      { i18n: "works.stack3.2", label: "Liquid" },
      { i18n: "works.stack3.3", label: "Custom Theme" },
    ],
  },
  {
    url: "https://eltoquedeoro.com/",
    img: "/images/toque.webp",
    alt: "El Toque de Oro",
    i18nCat: "works.cat4", cat: "Financial services",
    i18nTitle: "works.title4", title: "El Toque de Oro",
    i18nDesc: "works.desc4", desc: "Straightforward landing page with clear offers and quick contact.",
    stack: [
      { i18n: "works.stack4.1", label: "WordPress" },
      { i18n: "works.stack4.2", label: "PHP" },
      { i18n: "works.stack4.3", label: "Elementor" },
    ],
  },
  {
    url: "https://whatalog.vercel.app/",
    img: "/images/whatalog.webp",
    alt: "Whatalog",
    i18nCat: "works.cat5", cat: "Ecommerce Template",
    i18nTitle: "works.title5", title: "Whatalog",
    i18nDesc: "works.desc5", desc: "Turn your products into WhatsApp orders — no backend, no database, no hassle.",
    stack: [
      { i18n: "works.stack5.1", label: "NextJs" },
      { i18n: "works.stack5.2", label: "Astro" },
      { i18n: "works.stack5.3", label: "Vercel" },
    ],
  },
  {
    url: "https://javierlarrea.com",
    img: "/images/larrea.webp",
    alt: "Javier Larrea",
    i18nCat: "works.cat6", cat: "Portfolio",
    i18nTitle: "works.title6", title: "Javier Larrea",
    i18nDesc: "works.desc6", desc: "Minimal showcase for creative work, built to scroll clean and fast.",
    stack: [
      { i18n: "works.stack6.1", label: "HTML" },
      { i18n: "works.stack6.2", label: "CSS" },
      { i18n: "works.stack6.3", label: "JavaScript" },
    ],
  },
];
---

<section id="works" class="s-works target-section">
  <div class="row works-portfolio">
    <div class="column lg-12" data-animate-block>
      <h2 class="text-pretitle" data-animate-el data-i18n="works.pretitle">My Stuff</h2>
      <p class="h1" data-animate-el data-i18n="works.title">Real projects I shipped. No fluff, no filler.</p>

      <div class="folio-grid">
        {projects.map((p) => (
          <a href={p.url} class="folio-card" data-animate-el>
            <div class="folio-card__img-wrap">
              <img src={p.img} alt={p.alt} class="folio-card__img" loading="lazy" />
              <span class="folio-card__btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </div>
            <div class="folio-card__body">
              <span class="folio-card__cat" data-i18n={p.i18nCat}>{p.cat}</span>
              <span class="folio-card__title" data-i18n={p.i18nTitle}>{p.title}</span>
              <span class="folio-card__desc" data-i18n={p.i18nDesc}>{p.desc}</span>
              <div class="folio-card__stack">
                {p.stack.map((t) => (
                  <span class="folio-card__stack-item" data-i18n={t.i18n}>{t.label}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

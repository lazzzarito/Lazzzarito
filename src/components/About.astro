---

const services = [
  {
    i18n: "services.dev", label: "Custom Web Builds",
    i18nDesc: "services.devDesc", desc: "Not templates, actual work built from the ground up.",
    gridArea: "featured1", icon: "code",
  },
  {
    i18n: "services.frontend", label: "Frontend Development",
    i18nDesc: "services.frontendDesc", desc: "Solid, optimized code that loads fast and works everywhere.",
    gridArea: "normal1", icon: "layout",
  },
  {
    i18n: "services.fixes", label: "Site Fixes & Rescue",
    i18nDesc: "services.fixesDesc", desc: "Patch, rebuild, or rescue old projects before they fall apart.",
    gridArea: "normal2", icon: "wrench",
  },
  {
    i18n: "services.design", label: "UI/UX Design",
    i18nDesc: "services.designDesc", desc: "Interfaces people can actually use, not just pretty mockups.",
    gridArea: "normal3", icon: "palette",
  },
  {
    i18n: "services.consulting", label: "Technical Consulting",
    i18nDesc: "services.consultingDesc", desc: "Real talk on your web strategy, no corporate jargon.",
    gridArea: "normal4", icon: "message",
  },
  {
    i18n: "services.nocode", label: "No-Code Solutions",
    i18nDesc: "services.nocodeDesc", desc: "Fast wins with WordPress, Webflow, and tools that matter.",
    gridArea: "featured2", icon: "zap",
  },
];

const iconPaths = {
  code: '<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>',
  layout: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line>',
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>',
  palette: '<circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"></circle><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"></circle><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"></circle><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"></circle><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-1 0-.83.67-1.5 1.5-1.5H16c3.31 0 6-2.69 6-6 0-4.97-4.48-9-10-9z"></path>',
  message: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>',
};

const rows = [
  [
    { key: "html", color: "#e34f26", label: "HTML" },
    { key: "css", color: "#1572b6", label: "CSS" },
    { key: "javascript", color: "#f7df1e", label: "JavaScript" },
    { key: "typescript", color: "#3178c6", label: "TypeScript" },
    { key: "react", color: "#61dafb", label: "React" },
    { key: "nextjs", color: "#ffffff", label: "NextJs" },
    { key: "astro", color: "#bc52ee", label: "Astro" },
    { key: "php", color: "#777bb4", label: "PHP" },
  ],
  [
    { key: "nodejs", color: "#339933", label: "Node.js" },
    { key: "python", color: "#3776ab", label: "Python" },
    { key: "kotlin", color: "#7f52ff", label: "Kotlin" },
    { key: "git", color: "#f05032", label: "Git" },
    { key: "docker", color: "#2496ed", label: "Docker" },
    { key: "linux", color: "#fcc624", label: "Linux" },
    { key: "sql", color: "#e38c00", label: "SQL" },
    { key: "databases", color: "#336791", label: "Databases" },
  ],
  [
    { key: "wordpress", color: "#21759b", label: "WordPress" },
    { key: "woocommerce", color: "#96588a", label: "WooCommerce" },
    { key: "shopify", color: "#7ab55c", label: "Shopify" },
    { key: "webflow", color: "#4353ff", label: "Webflow" },
    { key: "framer", color: "#0055ff", label: "Framer" },
    { key: "figma", color: "#f24e1e", label: "Figma" },
    { key: "tailwind", color: "#38b2ac", label: "Tailwind" },
    { key: "ai", color: "#ff6b6b", label: "AI" },
  ],
];
---

<section id="about" class="s-about target-section">
  <div class="row about-info wide" data-animate-block>
    <div class="column lg-6 md-12 about-info__pic-block">
      <img src="/images/about.webp" alt="" class="about-info__pic" data-animate-el />
    </div>

    <div class="column lg-6 md-12">
      <div class="about-info__text">
        <h2 class="text-pretitle with-line" data-animate-el data-i18n="about.pretitle">About me</h2>
        <p class="attention-getter" data-animate-el>
          <span data-i18n="about.desc1">I take busted websites, slap them back together, and make them move. No bullshit.</span>
          <br /><br />
          <span data-i18n="about.desc2">Clean code, fast loads, and sites that don't act up when the traffic hits. If your current page is weak, I make it tight.</span>
        </p>
        <a href="#contact" class="btn btn--medium u-fullwidth" data-animate-el data-i18n="about.cta">Hit me up</a>
      </div>
    </div>
  </div>

  <div class="row about-expertise" data-animate-block>
    <div class="column lg-12">
      <h2 class="text-pretitle" data-animate-el data-i18n="skills.title">Skills</h2>

      <div class="skill-tracks" data-animate-el>
        {rows.map((track) => (
          <div class="skill-track">
            <div class="skill-track__inner">
              {[...track, ...track].map((s) => (
                <span class="skill-track__pill" style={`--pill-color: ${s.color}`}>
                  <svg class="skill-track__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"></polyline>
                    <polyline points="8 6 2 12 8 18"></polyline>
                  </svg>
                  <span data-i18n={`skills.${s.key}`}>{s.label}</span>
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="row about-services" data-animate-block>
    <div class="column lg-12">
      <h2 class="text-pretitle" data-animate-el data-i18n="services.title">What I do</h2>
      <div class="bento-grid" data-animate-el>
        {services.map((svc) => (
          <div class="bento-card" style={`grid-area: ${svc.gridArea}`}>
            <div class="bento-card__header">
              <svg class="bento-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[svc.icon]}></svg>
              <span class="bento-card__title" data-i18n={svc.i18n}>{svc.label}</span>
            </div>
            <p class="bento-card__desc" data-i18n={svc.i18nDesc}>{svc.desc}</p>
            <a href="https://wa.me/+5354703466" class="bento-card__wa" target="_blank" aria-label="Contact via WhatsApp">
              <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
